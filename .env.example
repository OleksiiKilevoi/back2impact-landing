# Cloudflare Worker endpoint that receives waitlist signups.
# Copy this file to `.env` and set the deployed Worker URL.
# (This URL is called from the browser, so it is NOT secret.)
VITE_WAITLIST_ENDPOINT=https://back2impact-waitlist.<your-subdomain>.workers.dev

# Cloudflare Turnstile sitekey (public — safe to ship to the browser).
# Local dev can use Cloudflare's "always passes" TEST sitekey: 1x00000000000000000000AA
VITE_TURNSTILE_SITEKEY=1x00000000000000000000AA
