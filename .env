# Cloudflare Worker endpoint that receives waitlist signups.
# Set this to the deployed Worker URL after `npm run worker:deploy`, e.g.
#   https://back2impact-waitlist.<your-subdomain>.workers.dev
VITE_WAITLIST_ENDPOINT=https://back2impact-waitlist.oleksii-kilevoi.workers.dev

# Cloudflare Turnstile sitekey (public — safe to ship to the browser).
# Default below is Cloudflare's "always passes" TEST sitekey for local dev.
# Replace with your real sitekey from the Turnstile dashboard before deploying.
VITE_TURNSTILE_SITEKEY=0x4AAAAAADl5YoWnU4W8pHG5
